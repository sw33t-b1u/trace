{
  "$defs": {
    "ActorRationale": {
      "additionalProperties": true,
      "description": "Human-readable and structured rationale for ActorTriageEntry.",
      "properties": {
        "capability_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Capability Factors",
          "type": "object"
        },
        "intent_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Intent Factors",
          "type": "object"
        },
        "opportunity_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Opportunity Factors",
          "type": "object"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ActorRationale",
      "type": "object"
    },
    "ActorScoreBreakdown": {
      "additionalProperties": true,
      "description": "Structured score breakdown for ActorTriageEntry.",
      "properties": {
        "capability": {
          "$ref": "#/$defs/ScoreComponent"
        },
        "data_quality": {
          "$ref": "#/$defs/DataQuality"
        },
        "intent": {
          "$ref": "#/$defs/ScoreComponent"
        },
        "opportunity": {
          "$ref": "#/$defs/ScoreComponent"
        }
      },
      "required": [
        "intent",
        "capability",
        "opportunity"
      ],
      "title": "ActorScoreBreakdown",
      "type": "object"
    },
    "ActorTriageEntry": {
      "additionalProperties": true,
      "description": "Single actor triage entry from BEACON 0.15.0 ``prioritized_actors[]``.\n\nBEACON 0.15.0+ emits one entry per scored threat actor; TRACE 1.8.0+\nvalidates each entry.  ``extra='allow'`` ensures forward compatibility\nwith future BEACON sub-fields without requiring a TRACE version bump.\nCanonical sub-factor names (per plan §3.3, renamed in Initiative F §3):\n  Capability: ttp_count_norm, sophistication_score, recency_active_campaigns\n  Opportunity: victimology_match, geographic_match, surface_ttp_coverage",
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "likelihood": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Likelihood",
          "type": "number"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "rationale": {
          "$ref": "#/$defs/ActorRationale"
        },
        "score_breakdown": {
          "$ref": "#/$defs/ActorScoreBreakdown"
        }
      },
      "required": [
        "actor_id",
        "name",
        "likelihood",
        "score_breakdown",
        "rationale"
      ],
      "title": "ActorTriageEntry",
      "type": "object"
    },
    "AssetWeightRule": {
      "additionalProperties": false,
      "properties": {
        "criticality_multiplier": {
          "exclusiveMinimum": 0.0,
          "title": "Criticality Multiplier",
          "type": "number"
        },
        "tag": {
          "minLength": 1,
          "title": "Tag",
          "type": "string"
        }
      },
      "required": [
        "tag",
        "criticality_multiplier"
      ],
      "title": "AssetWeightRule",
      "type": "object"
    },
    "DataQuality": {
      "additionalProperties": true,
      "description": "Data quality metadata for actor triage entries.",
      "properties": {
        "degraded": {
          "default": false,
          "title": "Degraded",
          "type": "boolean"
        },
        "missing_sources": {
          "items": {
            "type": "string"
          },
          "title": "Missing Sources",
          "type": "array"
        }
      },
      "title": "DataQuality",
      "type": "object"
    },
    "PIRItem": {
      "additionalProperties": true,
      "description": "Single PIR entry.\n\nMirrors SAGE's ``PIRFilter.from_file`` consumer in shape, while\naccepting the richer field set BEACON's generator emits\n(``intelligence_level``, ``rationale``, ``risk_score`` etc.) so\nBEACON-authored PIRs round-trip without loss.",
      "properties": {
        "asset_weight_rules": {
          "items": {
            "$ref": "#/$defs/AssetWeightRule"
          },
          "title": "Asset Weight Rules",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "intelligence_level": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intelligence Level"
        },
        "organizational_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Organizational Scope"
        },
        "pir_id": {
          "minLength": 1,
          "title": "Pir Id",
          "type": "string"
        },
        "prioritized_actors": {
          "items": {
            "$ref": "#/$defs/ActorTriageEntry"
          },
          "title": "Prioritized Actors",
          "type": "array"
        },
        "threat_actor_tags": {
          "items": {
            "type": "string"
          },
          "title": "Threat Actor Tags",
          "type": "array"
        },
        "valid_from": {
          "format": "date",
          "title": "Valid From",
          "type": "string"
        },
        "valid_until": {
          "format": "date",
          "title": "Valid Until",
          "type": "string"
        }
      },
      "required": [
        "pir_id",
        "valid_from",
        "valid_until"
      ],
      "title": "PIRItem",
      "type": "object"
    },
    "ScoreComponent": {
      "additionalProperties": false,
      "description": "Generic I×C×O score component — strict mode (TRACE 1.9.0).\n\nUsed for intent / capability / opportunity sub-breakdowns in\nActorTriageEntry.  As of TRACE 1.9.0 (paired with BEACON 0.16.0) the\ncanonical sub-factor names are enumerated and ``extra='forbid'`` rejects\nunknown fields, catching typos and silent producer drift.  Adding a new\nsub-factor requires bumping ``SUPPORTED_PIR_SCHEMA_VERSIONS`` and\nextending this model.\n\nSub-factor sets (per plan §3.3 + Initiative E §2.3/§2.4 + Initiative F §3):\n  Intent:       motivation_alignment, industry_match\n  Capability:   ttp_count_norm, sophistication_score,\n                recency_active_campaigns, tool_sophistication,\n                targeting_persistence, evasion_capability, depth, breadth\n  Opportunity:  victimology_match, geographic_match, surface_ttp_coverage\n\nField rename (Initiative F / TRACE 1.10.0 paired with BEACON 0.17.0):\n  ``recency_active_campaigns_90d`` → ``recency_active_campaigns``.\n  No Pydantic alias is exposed; the per-version normaliser on\n  ``PIROutputDocument`` rewrites ``_90d``-suffixed keys to the\n  canonical name for ``schema_version == \"0.16.0\"`` and rejects the\n  legacy key for ``\"0.17.0\"``. The schema_version gate enforces a\n  clean transition rather than indefinitely tolerating both names.",
      "properties": {
        "breadth": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Breadth"
        },
        "depth": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Depth"
        },
        "evasion_capability": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evasion Capability"
        },
        "geographic_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geographic Match"
        },
        "industry_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Industry Match"
        },
        "motivation_alignment": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Motivation Alignment"
        },
        "recency_active_campaigns": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recency Active Campaigns"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "sophistication_score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sophistication Score"
        },
        "surface_ttp_coverage": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Surface Ttp Coverage"
        },
        "targeting_persistence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Targeting Persistence"
        },
        "tool_sophistication": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Sophistication"
        },
        "ttp_count_norm": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ttp Count Norm"
        },
        "victimology_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Victimology Match"
        }
      },
      "required": [
        "score"
      ],
      "title": "ScoreComponent",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Document-level schema for pir_output.json (BEACON 0.16.0+).\n\nMirrors BEACON's ``PIROutputDocument`` shape for drift-check alignment.\n``schema_version`` is required; bundles without it or with a value outside\n``SUPPORTED_PIR_SCHEMA_VERSIONS`` are rejected so unannounced producer\nschema changes cannot slip through to SAGE ingestion.",
  "properties": {
    "pirs": {
      "items": {
        "$ref": "#/$defs/PIRItem"
      },
      "title": "Pirs",
      "type": "array"
    },
    "schema_version": {
      "description": "Semantic version of the pir_output schema.",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "pirs"
  ],
  "title": "PIROutputDocument",
  "type": "object"
}
