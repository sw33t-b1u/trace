{
  "$defs": {
    "ActorRationale": {
      "additionalProperties": true,
      "description": "Human-readable and structured rationale for ActorTriageEntry.",
      "properties": {
        "capability_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Capability Factors",
          "type": "object"
        },
        "intent_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Intent Factors",
          "type": "object"
        },
        "opportunity_factors": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Opportunity Factors",
          "type": "object"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ActorRationale",
      "type": "object"
    },
    "ActorScoreBreakdown": {
      "additionalProperties": true,
      "description": "Structured score breakdown for ActorTriageEntry.",
      "properties": {
        "capability": {
          "$ref": "#/$defs/ScoreComponent"
        },
        "data_quality": {
          "$ref": "#/$defs/DataQuality"
        },
        "intent": {
          "$ref": "#/$defs/ScoreComponent"
        },
        "opportunity": {
          "$ref": "#/$defs/ScoreComponent"
        }
      },
      "required": [
        "intent",
        "capability",
        "opportunity"
      ],
      "title": "ActorScoreBreakdown",
      "type": "object"
    },
    "ActorTriageEntry": {
      "additionalProperties": true,
      "description": "Single actor triage entry from BEACON's ``prioritized_actors[]``.\n\n``extra='allow'`` keeps the entry forward-compatible with additive\nBEACON sub-field additions (additive only, allowed in minor\nreleases).",
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "likelihood": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Likelihood",
          "type": "number"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "rationale": {
          "$ref": "#/$defs/ActorRationale"
        },
        "score_breakdown": {
          "$ref": "#/$defs/ActorScoreBreakdown"
        }
      },
      "required": [
        "actor_id",
        "name",
        "likelihood",
        "score_breakdown",
        "rationale"
      ],
      "title": "ActorTriageEntry",
      "type": "object"
    },
    "AssetWeightRule": {
      "additionalProperties": false,
      "properties": {
        "criticality_multiplier": {
          "exclusiveMinimum": 0.0,
          "title": "Criticality Multiplier",
          "type": "number"
        },
        "tag": {
          "minLength": 1,
          "title": "Tag",
          "type": "string"
        }
      },
      "required": [
        "tag",
        "criticality_multiplier"
      ],
      "title": "AssetWeightRule",
      "type": "object"
    },
    "DataQuality": {
      "additionalProperties": true,
      "description": "Data quality metadata for actor triage entries.\n\n``extra='allow'`` is preserved so new additive quality flags can be\nadded without a TRACE major bump (additive changes stay on\nschema_version 2.0.0 per api-stability.md).",
      "properties": {
        "degraded": {
          "default": false,
          "title": "Degraded",
          "type": "boolean"
        },
        "ir_boost_skipped": {
          "default": false,
          "title": "Ir Boost Skipped",
          "type": "boolean"
        },
        "missing_sources": {
          "items": {
            "type": "string"
          },
          "title": "Missing Sources",
          "type": "array"
        }
      },
      "title": "DataQuality",
      "type": "object"
    },
    "PIRItem": {
      "additionalProperties": true,
      "description": "Single PIR entry.\n\nMirrors SAGE's ``PIRFilter.from_file`` consumer in shape, while\naccepting the richer field set BEACON's generator emits\n(``intelligence_level``, ``rationale``, ``risk_score`` etc.) so\nBEACON-authored PIRs round-trip without loss.",
      "properties": {
        "asset_weight_rules": {
          "items": {
            "$ref": "#/$defs/AssetWeightRule"
          },
          "title": "Asset Weight Rules",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "intelligence_level": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intelligence Level"
        },
        "organizational_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Organizational Scope"
        },
        "pir_id": {
          "minLength": 1,
          "title": "Pir Id",
          "type": "string"
        },
        "prioritized_actors": {
          "items": {
            "$ref": "#/$defs/ActorTriageEntry"
          },
          "title": "Prioritized Actors",
          "type": "array"
        },
        "threat_actor_tags": {
          "items": {
            "type": "string"
          },
          "title": "Threat Actor Tags",
          "type": "array"
        },
        "valid_from": {
          "format": "date",
          "title": "Valid From",
          "type": "string"
        },
        "valid_until": {
          "format": "date",
          "title": "Valid Until",
          "type": "string"
        }
      },
      "required": [
        "pir_id",
        "valid_from",
        "valid_until",
        "prioritized_actors"
      ],
      "title": "PIRItem",
      "type": "object"
    },
    "ScoreComponent": {
      "additionalProperties": false,
      "description": "Generic I×C×O score component — strict mode.\n\nUsed for intent / capability / opportunity sub-breakdowns in\nActorTriageEntry. ``extra='forbid'`` rejects unknown fields,\ncatching typos and silent producer drift. Adding a new sub-factor\nrequires bumping ``SUPPORTED_PIR_SCHEMA_VERSIONS`` and extending\nthis model.\n\nCanonical sub-factor names (committed surface; see ``docs/api-stability.md``):\n  Intent:       motivation_alignment, industry_match, ir_observed\n  Capability:   ttp_count_norm, sophistication_score,\n                recency_active_campaigns, tool_usage,\n                targeting_persistence, evasion_capability, depth,\n                breadth\n  Opportunity:  victimology_match, geographic_match,\n                surface_ttp_coverage",
      "properties": {
        "breadth": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Breadth"
        },
        "depth": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Depth"
        },
        "evasion_capability": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evasion Capability"
        },
        "geographic_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geographic Match"
        },
        "industry_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Industry Match"
        },
        "ir_observed": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ir Observed"
        },
        "motivation_alignment": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Motivation Alignment"
        },
        "recency_active_campaigns": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recency Active Campaigns"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "sophistication_score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sophistication Score"
        },
        "surface_ttp_coverage": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Surface Ttp Coverage"
        },
        "targeting_persistence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Targeting Persistence"
        },
        "tool_usage": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Usage"
        },
        "ttp_count_norm": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ttp Count Norm"
        },
        "victimology_match": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Victimology Match"
        }
      },
      "required": [
        "score"
      ],
      "title": "ScoreComponent",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Document-level schema for pir_output.json (BEACON 2.0.0+).\n\nMirrors BEACON's ``PIROutputDocument`` shape for drift-check alignment.\n``schema_version`` is required; bundles without it or with a value\noutside ``SUPPORTED_PIR_SCHEMA_VERSIONS`` are rejected so unannounced\nproducer schema changes cannot slip through to SAGE ingestion.",
  "properties": {
    "pirs": {
      "items": {
        "$ref": "#/$defs/PIRItem"
      },
      "title": "Pirs",
      "type": "array"
    },
    "schema_version": {
      "description": "Semantic version of the pir_output schema.",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "pirs"
  ],
  "title": "PIROutputDocument",
  "type": "object"
}
