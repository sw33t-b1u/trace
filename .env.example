# GCP / Vertex AI
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1

# LLM model tier overrides (optional)
TRACE_LLM_SIMPLE=gemini-2.5-flash-lite
TRACE_LLM_MEDIUM=gemini-2.5-flash
TRACE_LLM_COMPLEX=gemini-2.5-pro

# PIR relevance gate (L2)
TRACE_RELEVANCE_MODEL_TIER=simple
TRACE_RELEVANCE_THRESHOLD=0.5

# STIX extraction (L3)
TRACE_EXTRACTION_CHUNK_CHARS=12000

# Crawler
TRACE_CRAWL_USER_AGENT=
TRACE_CRAWL_CONCURRENCY=4
TRACE_STATE_PATH=output/crawl_state.json

# External-reference hash sidecar (L4)
TRACE_EXTERNAL_REF_HASH_ENABLED=true
TRACE_EXTERNAL_REF_HASH_CACHE=output/external_ref_hash_cache.json
TRACE_EXTERNAL_REF_HASH_TTL_DAYS=30

# Threat-taxonomy auto-sync (1.7.0+)
TRACE_TAXONOMY_CACHE_PATH=schema/threat_taxonomy.cached.json
TRACE_BEACON_TAXONOMY_SOURCE=../BEACON/schema/threat_taxonomy.json

# GitHub Enterprise (optional, for cmd/submit_review.py --open-issue)
TRACE_GHE_TOKEN=
GHE_REPO=
GHE_API_BASE=https://api.github.com
